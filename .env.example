# BSP API Environment Variables

# REQUIRED: Secret key for JWT token signing
# Generate a secure random key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BSP_SECRET_KEY=your-secret-key-here-change-this-in-production

# REQUIRED: Encryption key for sensitive data (32 url-safe base64-encoded bytes)
# Generate with: docker run --rm wintermutant/bsp-api:latest python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or if you have cryptography installed locally: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BSP_ENCRYPTION_KEY=your-encryption-key-here-change-this-in-production

# OPTIONAL: Database path (defaults to ./data/bsp.db)
# BSP_DB_PATH=/app/data/bsp.db

# OPTIONAL: MongoDB URI (if using MongoDB)
# MONGO_URI=mongodb://admin:password123@localhost:27017/
